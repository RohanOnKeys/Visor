{
  "name": "visor-context-compiler",
  "version": "0.1.0",
  "description": "Compile raw webpage DOM into safe, structured, agent-ready context.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:extension": "vite build --watch",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
